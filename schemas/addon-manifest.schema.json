{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://shardana.ai/schemas/addon-manifest.json",
  "title": "Shardana Addon Manifest",
  "description": "Contract published by an add-on author. Each add-on repo ships an addon-manifest.json that declares its injection kind, default URL, and accepted params. The Heroic build pipeline validates plan.yml addons[] against this manifest.",
  "type": "object",
  "required": ["id", "name", "version", "injection", "src"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Stable kebab-case slug. Must match plan.yml addons[].id."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$",
      "description": "Semantic version (e.g. 1.2.3, 1.0.0-beta.2)."
    },
    "description": { "type": "string", "minLength": 1 },
    "injection": { "enum": ["script", "iframe", "web-component"] },
    "src": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "description": "Default URL of the add-on asset (script, iframe page, or custom-element bundle)."
    },
    "params": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": { "enum": ["string", "number", "boolean"] },
          "required": { "type": "boolean", "default": false },
          "description": { "type": "string", "minLength": 1 },
          "default": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          },
          "enum": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          }
        }
      }
    },
    "tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*-[a-z0-9-]*$",
      "description": "Custom element tag (kebab-case, must contain a hyphen). Only used for injection: web-component."
    },
    "homepage": { "type": "string", "format": "uri" },
    "maintainer": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 }
  }
}
