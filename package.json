{
  "name": "@shardana/addon-injector",
  "version": "0.1.0",
  "description": "Inject Heroic Landing add-ons (script, iframe, web-component) into the DOM. Build-time HTML or runtime DOM, validated against a manifest.",
  "license": "MIT",
  "homepage": "https://github.com/shardana-ai/addon-injector",
  "repository": {
    "type": "git",
    "url": "https://github.com/shardana-ai/addon-injector.git"
  },
  "author": "shardana.ai",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/umd/shardana-addon-injector.umd.global.js",
  "jsdelivr": "./dist/umd/shardana-addon-injector.umd.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "require": "./dist/manifest.cjs"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js",
      "require": "./dist/render.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "schemas"
  ],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "build:size": "tsup && gzip -c dist/umd/shardana-addon-injector.umd.global.js | wc -c",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "shardana",
    "heroic",
    "addon",
    "injector",
    "widget",
    "embed"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "happy-dom": "^15.7.4",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  },
  "sideEffects": false
}
